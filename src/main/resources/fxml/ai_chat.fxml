<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.easyforge.controller.AIChatController">
    <children>
        <VBox spacing="10" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="AI 助手" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="选择模型:"/>
                <ComboBox fx:id="providerCombo" prefWidth="150"/>
                <Label text="API Key:"/>
                <PasswordField fx:id="apiKeyField" promptText="请输入 API Key" HBox.hgrow="ALWAYS"/>
                <Button fx:id="testConnectionBtn" text="测试连接"/>
                <Button fx:id="helpBtn" text="❓ 如何获取 Key"/>
                <Button fx:id="saveConfigBtn" text="保存配置"/>
            </HBox>

            <ListView fx:id="chatListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-control-inner-background: transparent;"/>

            <HBox spacing="10" alignment="BOTTOM_LEFT">
                <Button fx:id="uploadImageBtn" text="📷 截图/图片"/>
                <TextField fx:id="messageField" promptText="输入您的问题..." HBox.hgrow="ALWAYS"/>
                <Button fx:id="sendBtn" text="发送" styleClass="modern-button-primary"/>
            </HBox>
            <Label fx:id="imageStatusLabel" style="-fx-text-fill: gray; -fx-font-size: 12px;"/>
        </VBox>
    </children>
</AnchorPane>